<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Surprise Birthday! 💖🎉</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Dancing+Script:wght@400;700&family=Poppins:wght@300;400;600&display=swap');
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
            min-height: 100vh;
            overflow-x: hidden;
            position: relative;
        }

        /* Floating hearts and confetti */
        .background-animation {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 1;
        }

        .heart, .balloon {
            position: absolute;
            font-size: 20px;
            animation: float 6s infinite linear;
        }

        .balloon {
            font-size: 30px;
            animation: float 8s infinite linear;
        }

        @keyframes float {
            0% { transform: translateY(100vh) rotate(0deg); opacity: 1; }
            100% { transform: translateY(-100px) rotate(360deg); opacity: 0; }
        }

        /* Main container */
        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            position: relative;
            z-index: 10;
            text-align: center;
        }

        /* Header */
        .header {
            margin-bottom: 40px;
        }

        h1 {
            font-family: 'Dancing Script', cursive;
            font-size: 4rem;
            color: #ff6b9d;
            text-shadow: 3px 3px 0px #fff, 6px 6px 0px rgba(255,107,157,0.3);
            margin-bottom: 10px;
            animation: bounce 2s infinite;
        }

        @keyframes bounce {
            0%, 20%, 50%, 80%, 100% { transform: translateY(0); }
            40% { transform: translateY(-20px); }
            60% { transform: translateY(-10px); }
        }

        .subtitle {
            font-size: 1.5rem;
            color: #fff;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            margin-bottom: 30px;
        }

        /* Bears container */
        .bears {
            display: flex;
            justify-content: center;
            align-items: flex-end;
            gap: 50px;
            margin: 50px 0;
            flex-wrap: wrap;
        }

        .bear {
            width: 200px;
            height: 250px;
            position: relative;
            animation: wiggle 3s infinite;
        }

        .bear:nth-child(2) {
            animation-delay: 1s;
        }

        @keyframes wiggle {
            0%, 100% { transform: rotate(-3deg); }
            50% { transform: rotate(3deg); }
        }

        /* Bear body */
        .bear-body {
            width: 100%;
            height: 150px;
            background: linear-gradient(145deg, #d4a574, #e6c9a3);
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            position: relative;
            box-shadow: 10px 10px 20px rgba(0,0,0,0.2);
        }

        /* Bear head */
        .bear-head {
            width: 140px;
            height: 140px;
            background: linear-gradient(145deg, #d4a574, #e6c9a3);
            border-radius: 50%;
            position: absolute;
            top: -70px;
            left: 50%;
            transform: translateX(-50%);
            box-shadow: 8px 8px 16px rgba(0,0,0,0.2);
        }

        /* Ears */
        .ear {
            width: 40px;
            height: 40px;
            background: linear-gradient(145deg, #d4a574, #e6c9a3);
            border-radius: 50%;
            position: absolute;
            top: -10px;
        }

        .ear-left { left: 10px; }
        .ear-right { right: 10px; }

        .ear-inner {
            width: 20px;
            height: 20px;
            background: #ff6b9d;
            border-radius: 50%;
            position: absolute;
            top: 8px;
            left: 8px;
        }

        /* Eyes */
        .eye {
            width: 25px;
            height: 25px;
            background: #fff;
            border-radius: 50%;
            position: absolute;
            top: 40px;
            box-shadow: inset 3px 3px 5px rgba(0,0,0,0.3);
        }

        .eye-left { left: 25px; }
        .eye-right { right: 25px; }

        .pupil {
            width: 12px;
            height: 12px;
            background: #333;
            border-radius: 50%;
            position: absolute;
            top: 6px;
            left: 6px;
            animation: blink 4s infinite;
        }

        @keyframes blink {
            0%, 90%, 100% { height: 12px; }
            95% { height: 2px; }
        }

        /* Nose */
        .nose {
            width: 20px;
            height: 15px;
            background: #ff6b9d;
            border-radius: 50%;
            position: absolute;
            top: 70px;
            left: 50%;
            transform: translateX(-50%);
        }

        /* Mouth */
        .mouth {
            width: 30px;
            height: 20px;
            border: 3px solid transparent;
            border-bottom-color: #333;
            border-radius: 0 0 30px 30px;
            position: absolute;
            top: 85px;
            left: 50%;
            transform: translateX(-50%);
        }

        /* Accessories */
        .party-hat {
            width: 0;
            height: 0;
            border-left: 25px solid transparent;
            border-right: 25px solid transparent;
            border-bottom: 50px solid #ff6b9d;
            position: absolute;
            top: -30px;
            left: 50%;
            transform: translateX(-50%);
            clip-path: polygon(50% 0%, 0% 100%, 100% 100%);
        }

        .bowtie {
            position: absolute;
            top: 120px;
            left: 50%;
            transform: translateX(-50%);
        }

        .bowtie::before,
        .bowtie::after {
            content: '';
            position: absolute;
            width: 30px;
            height: 20px;
            background: #ff6b9d;
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
        }

        .bowtie::before { left: -20px; }
        .bowtie::after { right: -20px; }

        .bowtie-center {
            position: absolute;
            width: 12px;
            height: 12px;
            background: #fff;
            border-radius: 50%;
            left: 50%;
            top: 4px;
            transform: translateX(-50%);
        }

        /* Bear 2 special accessories */
        .sunglasses {
            position: absolute;
            top: 45px;
            left: 20px;
            width: 80px;
            height: 20px;
            background: #333;
            border-radius: 20px;
        }

        .sunglasses::before,
        .sunglasses::after {
            content: '';
            position: absolute;
            width: 25px;
            height: 20px;
            background: #333;
            border-radius: 50%;
            top: -5px;
        }

        .sunglasses::before { left: 5px; }
        .sunglasses::after { right: 5px; }

        /* Message section */
        .message {
            background: rgba(255,255,255,0.95);
            padding: 40px;
            border-radius: 30px;
            margin: 50px 20px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
            backdrop-filter: blur(10px);
        }

        .message h2 {
            font-family: 'Dancing Script', cursive;
            font-size: 2.5rem;
            color: #ff6b9d;
            margin-bottom: 20px;
        }

        .message p {
            font-size: 1.2rem;
            line-height: 1.6;
            color: #555;
            margin-bottom: 20px;
        }

        /* QR Code */
        .qr-section {
            margin: 40px 0;
        }

        .qr-code {
            width: 200px;
            height: 200px;
            margin: 20px auto;
            border: 10px solid #fff;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            background: #fff;
        }

        .qr-text {
            color: #ff6b9d;
            font-size: 1.1rem;
            font-weight: 600;
        }

        /* Cake */
        .cake {
            width: 200px;
            height: 150px;
            margin: 40px auto;
            position: relative;
        }

        .cake-base {
            width: 200px;
            height: 100px;
            background: linear-gradient(145deg, #d2691e, #f4a460);
            border-radius: 20px;
            position: absolute;
            bottom: 0;
            box-shadow: 0 10px 20px rgba(0,0,0,0.3);
        }

        .cake-top {
            width: 160px;
            height: 60px;
            background: linear-gradient(145deg, #ff69b4, #ff1493);
            border-radius: 15px 15px 5px 5px;
            position: absolute;
            top: 0;
            left: 20px;
        }

        .candle {
            width: 8px;
            height: 30px;
            background: #ffeb3b;
            position: absolute;
            top: -25px;
            right: 40px;
            border-radius: 4px;
        }

        .flame {
            width: 12px;
            height: 15px;
            background: radial-gradient(circle, #ff4500, #ff8c00);
            border-radius: 50% 50% 50% 50% / 60% 60% 40% 40%;
            position: absolute;
            top: -18px;
            right: 37px;
            animation: flicker 2s infinite;
        }

        @keyframes flicker {
            0%, 100% { transform: scale(1) rotate(-1deg); }
            50% { transform: scale(1.1) rotate(1deg); }
        }

        /* Button */
        .cta-button {
            display: inline-block;
            background: linear-gradient(45deg, #ff6b9d, #ff8fab);
            color: white;
            padding: 15px 40px;
            border-radius: 50px;
            text-decoration: none;
            font-weight: 600;
            font-size: 1.2rem;
            margin: 20px;
            box-shadow: 0 10px 30px rgba(255,107,157,0.4);
            transition: all 0.3s ease;
            animation: pulse 2s infinite;
        }

        .cta-button:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(255,107,157,0.6);
        }

        @keyframes pulse {
            0% { box-shadow: 0 10px 30px rgba(255,107,157,0.4); }
            50% { box-shadow: 0 10px 30px rgba(255,107,157,0.7); }
            100% { box-shadow: 0 10px 30px rgba(255,107,157,0.4); }
        }

        /* Responsive */
        @media (max-width: 768px) {
            h1 { font-size: 2.5rem; }
            .bears { gap: 20px; }
            .bear { width: 150px; height: 200px; }
            .message { padding: 20px; margin: 20px 10px; }
        }

        /* Love hearts around bears */
        .love-heart {
            position: absolute;
            color: #ff6b9d;
            font-size: 24px;
            animation: heartbeat 1.5s infinite;
        }

        @keyframes heartbeat {
            0% { transform: scale(1); }
            14% { transform: scale(1.3); }
            28% { transform: scale(1); }
            42% { transform: scale(1.3); }
            70% { transform: scale(1); }
        }
    </style>
</head>
